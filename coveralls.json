{
  "coverage_options": {
    "minimum_coverage": 80,
    "output_dir": "cover/",
    "treat_no_relevant_lines_as_covered": true
  },
  "terminal_options": {
    "file_column_width": 40
  },
  "skip_files": [
    "(^|/)_build/",
    "(^|/)cover/",
    "(^|/)deps/",
    "^priv/",
    "^test/",
    "^lib/squid_studio/application\\.ex$"
  ]
}
